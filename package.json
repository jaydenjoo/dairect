{
  "name": "dairect",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3700",
    "build": "next build --webpack",
    "postbuild": "test -f public/sw.js && echo '✓ SW artifact verified (public/sw.js)' || (echo '❌ public/sw.js missing — Serwist build did not run' && exit 1)",
    "start": "next start --port 3700",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "pwa:icons": "tsx scripts/generate-pwa-icons.mts",
    "dev:e2e": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres N8N_WEBHOOK_URL= NEXT_PUBLIC_APP_URL=http://localhost:3701 next dev --port 3701",
    "test:e2e": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres playwright test",
    "test:e2e:ui": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres playwright test --ui",
    "test:e2e:debug": "DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres PWDEBUG=1 playwright test",
    "test:e2e:prod": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@base-ui/react": "^1.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "serwist": "^9.5.7",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
