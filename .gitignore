# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist / PWA service worker (build artifact)
public/sw.js
public/sw.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map

# playwright e2e (build/run artifacts)
/playwright-report/
/test-results/
/playwright/.cache/

# Supabase local CLI (e2e 격리)
/supabase/.branches/
/supabase/.temp/
/supabase/seed.sql

# Claude Code — subagent memory/worktrees (local-only)
.claude/agent-memory/
.claude/worktrees/

# Playwright MCP artifacts (local-only)
.playwright-mcp/
